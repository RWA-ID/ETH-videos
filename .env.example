# ─── Web3 / RPC ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
NEXT_PUBLIC_ALCHEMY_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ALCHEMY_RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Livepeer ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LIVEPEER_API_KEY=your_livepeer_studio_api_key
LIVEPEER_API_KEY=your_livepeer_studio_api_key  # server-side

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud

# ─── Contract Addresses (after deployment) ────────────────────────────────────
NEXT_PUBLIC_VIDEO_POST_ADDRESS_MAINNET=0x...
NEXT_PUBLIC_TIP_CONTRACT_ADDRESS_MAINNET=0x...
NEXT_PUBLIC_REACTIONS_ADDRESS_MAINNET=0x...
NEXT_PUBLIC_TIP_CONTRACT_ADDRESS_BASE=0x...

# ─── Foundry / Deployment ────────────────────────────────────────────────────
PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...
TREASURY_ADDRESS=0x...  # ethvideos.eth multisig
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
ETHERSCAN_API_KEY=your_etherscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# ─── XMTP ────────────────────────────────────────────────────────────────────
# No API key needed for users — XMTP is a decentralized protocol.
# Bot key is only needed to send server-side notifications (tip alerts etc.)
XMTP_BOT_PRIVATE_KEY=0x...          # optional: notification bot private key
NEXT_PUBLIC_NOTIFICATION_BOT_ADDRESS=0x...  # optional: bot's public address

# ─── ENS / Subdomain ─────────────────────────────────────────────────────────
# app.ethvideos.eth — already in deployer wallet
# After deploying to Vercel, set ENS contenthash to the IPFS CID of the build
# or point the DNS record to Vercel's domain for ENS + DNS hybrid resolution
